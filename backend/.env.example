# Copy this file to backend/.env before running the API locally.
APP_NAME=AI Playwright Platform
APP_ENV=development
LOG_LEVEL=INFO
# Async SQLAlchemy URL consumed by app.config.settings.
DATABASE_URL=postgresql+asyncpg://aiops:AIOps!1234@127.0.0.1:5432/runlet
# Redis endpoint consumed by the queued-job dispatcher.
REDIS_URL=redis://127.0.0.1:6379/0
