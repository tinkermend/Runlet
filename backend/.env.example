# 复制为 backend/.env 后再启动本地 API 或 worker。
# 同一组变量同时供 auth/crawl worker 使用。
APP_NAME=AI Playwright Platform
APP_ENV=development
LOG_LEVEL=INFO
# API 与 worker 共用的异步数据库连接串。
DATABASE_URL=postgresql+asyncpg://aiops:AIOps!1234@127.0.0.1:5432/runlet
# control plane 入队链路使用的 Redis 地址。
REDIS_URL=redis://127.0.0.1:6379/0

# Web 控制台会话配置（前端 cookie 会话登录）。
SESSION_SECRET=change-me
SESSION_TTL_HOURS=8

# 可选：密码哈希 pepper（为空表示不启用）。
PASSWORD_PEPPER=

# Skills 用临时 PAT 配置（仅允许的天数建议与产品策略一致）。
PAT_MAX_TTL_DAYS=7
PAT_ALLOWED_TTL_DAYS=3,7
